{
  "compilerOptions": {
    /* Basic Options */
    "target": "ES2022",
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "ignoreDeprecations": "6.0",
    "resolveJsonModule": true,
    "types": [
      "node"
    ],
    "noEmitOnError": true,
    "lib": ["esnext", "dom"],
    "module": "ESNext",
    /* Source Map Options */
    "sourceMap": true,
    /* Module Resolution Options */
    "baseUrl": "src",
    "paths": {
      "@/*": ["*"],
      "@models/*": ["models/*"],
      "@routes/*": [
        "routes/*"
      ],
      "@modelTypes/*": [
        "model_types/*"
      ],
      "@controllers/*": [
        "controllers/*"
      ],
      "@utilities/*": [
        "utilities/*"
      ],
      "@core/*": [
        "core/*"
      ],
    },
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    
    /* Additional Checks */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "typeRoots": [
      "./node_modules/@types",
      "./src/types"
    ]
  },
  "include": [
    "**/*.d.ts",
    "**/*.ts",
    "src/config/useBackendConfig.ts",
    "env.d.ts",
    "src/**/*"
  ],
  "exclude": [
    "node_modules"
  ]
}